    "client.js",
    "server.d.ts",
    "server.js"
  ],
  "devDependencies": {
    "@types/body-parser": "^1.19.0",
    "@types/chai": "^4.2.9",
    "@types/chai-as-promised": "^7.1.2",
    "@types/compression": "^1.0.1",
    "@types/cookie-parser": "^1.4.2",
    "@types/express": "^4.17.6",
    "@types/express-useragent": "^1.0.0",
    "@types/mocha": "^7.0.1",
    "@types/morgan": "^1.9.3",
    "@typescript-eslint/parser": "^8.59.2",
    "body-parser": "^1.19.0",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.4",
    "eslint": "^8.57.1",
    "express-useragent": "^1.0.13",
    "mocha": "^7.0.1",
    "morgan": "^1.10.0",
    "prettier": "^2.4.0",
    "standard-version": "^9.3.1",
    "ts-node": "^8.6.2",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
