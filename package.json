    "url": "https://github.com/antman261/zod-http-schemas.git"
  },
  "prettier": {
    "singleQuote": true
  },
  "keywords": [
    "zod",
    "express",
    "api",
    "schemas",
    "runtime types",
    "backend"
  ],
  "author": {
    "name": "Anthony Manning-Franklin",
    "email": "anthony.manning.franklin@gmail.com",
    "url": "https://antman-does-software.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/antman261/zod-http-schemas/issues"
  },
