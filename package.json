{
  "name": "zod-http-schemas",
  "version": "3.0.0",
  "description": "Zod Powered, strongly-typed HTTP schemas",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "mocha \"src/**/*.test.ts\"",
    "release": "npm run build && git add . && standard-version"
  },
  "mocha": {
    "require": "ts-node/register"
